{
  "name": "asafarim-platform",
  "version": "0.1.0",
  "private": true,
  "description": "ASafarIM Platform - unified monorepo for all ASafarIM Digital apps and services",
  "author": "Ali Safari",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @asafarim/db db:generate",
    "db:migrate": "pnpm --filter @asafarim/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @asafarim/db db:migrate:deploy",
    "db:push": "pnpm --filter @asafarim/db db:push",
    "db:studio": "pnpm --filter @asafarim/db db:studio",
    "db:seed": "pnpm --filter @asafarim/db db:seed",
    "deploy:prod": "bash ./infra/scripts/deploy-prod.sh"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  }
}
