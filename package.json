{
  "name": "asafarim-platform",
  "version": "0.1.0",
  "private": true,
  "description": "ASafarIM Platform - unified monorepo for all ASafarIM Digital apps and services",
  "author": "Ali Safari",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "kill-port 3000 3001 3002 3003 && turbo dev",
    "clean": "rimraf node_modules .turbo && turbo clean",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "env:status": "envage status",
    "env:check": "node scripts/check-env-safety.mjs",
    "env:key:init": "envage init-key",
    "env:encrypt:local": "envage encrypt --all --env root",
    "env:decrypt:local": "envage decrypt --all --env root",
    "env:encrypt:production": "envage encrypt --all --env production",
    "env:decrypt:production": "envage decrypt --all --env production",
    "db:generate": "pnpm --filter @asafarim/db db:generate",
    "db:migrate": "pnpm --filter @asafarim/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @asafarim/db db:migrate:deploy",
    "db:push": "pnpm --filter @asafarim/db db:push",
    "db:studio": "pnpm --filter @asafarim/db db:studio",
    "db:seed": "pnpm --filter @asafarim/db db:seed",
    "deploy:prod": "bash ./infra/scripts/deploy-prod.sh"
  },
  "devDependencies": {
    "@asafarim/envage": "^0.4.2",
    "kill-port": "^2.0.1",
    "prettier": "^3.5.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  }
}
