{
  "name": "@asafarim/appbuilder",
  "version": "0.1.0",
  "private": true,
  "description": "ASafarIM AppBuilder - metadata-driven AI application factory (appbuilder.asafarim.com)",
  "scripts": {
    "dev": "next dev --port 3006",
    "build": "next build",
    "start": "next start --port 3006",
    "lint": "echo \"Lint skipped for Next.js 16 app; covered by typecheck/build\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@asafarim/ui": "workspace:*",
    "dotenv": "^17.4.2",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@asafarim/config": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
