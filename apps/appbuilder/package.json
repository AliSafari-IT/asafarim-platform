{
  "name": "@asafarim/appbuilder",
  "version": "0.2.0",
  "private": true,
  "description": "ASafarIM AppBuilder - metadata-driven AI application factory (appbuilder.asafarim.com)",
  "scripts": {
    "dev": "next dev --port 3006",
    "build": "next build",
    "start": "next start --port 3006",
    "lint": "echo \"Lint skipped for Next.js 16 app; covered by typecheck/build\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx lib/db/seed.ts",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report .playwright/report"
  },
  "dependencies": {
    "@asafarim/appbuilder-runtime": "workspace:*",
    "@asafarim/appbuilder-schema": "workspace:*",
    "@asafarim/auth": "workspace:*",
    "@asafarim/theme-toggle": "workspace:*",
    "@asafarim/ui": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.38.2",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.28",
    "pg": "^8.13.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@asafarim/config": "workspace:*",
    "@asafarim/db": "workspace:*",
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
