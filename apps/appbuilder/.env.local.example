# Most vars are already provided by the monorepo root .env.local / .env
# (loaded automatically by next.config.ts). Set app-only overrides here in an
# apps/appbuilder/.env.local if you need them.

# AppBuilder keeps its OWN database, separate from the platform's shared
# Prisma Postgres and from testora's. Matches the `appbuilder-postgres`
# service in the root docker-compose.yml (host port 55436).
APPBUILDER_DATABASE_URL=postgres://appbuilder:appbuilder_dev@localhost:55436/appbuilder

# AppBuilder authenticates via the shared platform SSO session — it has no
# auth vars of its own. AUTH_SECRET, AUTH_COOKIE_DOMAIN, and every
# NEXT_PUBLIC_*_URL (used for the trusted-origin/callback allowlist and the
# app switcher) come from the monorepo root .env.local / .env, same as
# every other app. See docs/appbuilder-architecture.md for the SSO flow.
#
# AppBuilder's AI provider and preview-runtime config ship in later
# milestones (M07) and will be documented here when they land.
