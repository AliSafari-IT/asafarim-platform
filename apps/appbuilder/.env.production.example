# AppBuilder keeps its OWN database, separate from the platform's shared
# Postgres. Most vars are already provided by the monorepo root
# .env.production; set app-only overrides here only if AppBuilder ever needs
# a distinct production environment file (see docs/environment-management.md
# for when that split is warranted).
#
# DO NOT commit real secrets to version control.

# Production Postgres connection for AppBuilder's own database. Compose
# builds this from APPBUILDER_DB_PASSWORD (see root .env.production.example)
# and the in-network appbuilder-postgres service — this line documents the
# shape for reference/manual runs.
# Example: postgres://appbuilder:<password>@appbuilder-postgres:5432/appbuilder
APPBUILDER_DATABASE_URL=
