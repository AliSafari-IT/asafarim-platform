# testora keeps its OWN database, separate from the platform's shared Postgres.
# Most vars below are already provided by the monorepo root .env.local / .env
# (loaded automatically by next.config.ts); set app-only overrides here in an
# apps/testora/.env.local if you need them.
#
# DO NOT commit real secrets to version control. Populate this file with
# production values, then encrypt it with `pnpm env:encrypt:production`.

# Production Postgres connection for the testora E2E database.
# Example: postgres://user:password@host:port/database
TESTORA_DATABASE_URL=

# Public base URL where testora is served in production.
BASE_URL=https://testora.asafarim.com

# Optional: AI-drafted issue content for the Results "Generate issue" flow.
# Without a key, issues fall back to a deterministic template. Server-only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_MAX_OUTPUT_TOKENS=8000

# Secret used to sign the "unlock" cookie for private apps (server-side only).
# Set a long random value in any shared/production deployment — otherwise the
# unlock cookie falls back to a known dev secret and could be forged.
TESTORA_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# App under test (the "target") — testora is generic, so nothing about the
# specific app is hard-coded. Set these to whatever web app you point it at.
# ─────────────────────────────────────────────────────────────────────────────

# Credentials of the test account the suites log in with (must be admin /
# superadmin for the admin suites). Temp accounts are plus-addressed off this
# email so they land in an inbox you control.
WEBAPP_ADMIN_EMAIL=
WEBAPP_ADMIN_PASSWORD=
WEBAPP_ROLE=superadmin

ASAFARIM_ADMIN_EMAIL=
ASAFARIM_ADMIN_PASSWORD=

# Production target for the app under test.
WEBAPP_BASE_URL=https://asafarim.com
WEBAPP_API_URL=https://api.asafarim.com/api/v1

# Optional remote/staging target, surfaced as the "Remote" preset on the Run
# page's environment selector. Leave blank to hide it.
# NEXT_PUBLIC_* values are needed because the Run page reads them in the browser.
NEXT_PUBLIC_WEBAPP_BASE_URL=https://asafarim.com
NEXT_PUBLIC_WEBAPP_API_URL=https://api.asafarim.com/api/v1
NEXT_PUBLIC_WEBAPP_REMOTE_BASE_URL=
NEXT_PUBLIC_WEBAPP_REMOTE_API_URL=

# Optional overrides for the Immo Local app. Defaults to the same local dev
# target as ImmoStory above.
# NEXT_PUBLIC_IMMO_LOCAL_NAME=Immo Local
# NEXT_PUBLIC_IMMO_LOCAL_BASE_URL=https://asafarim.com
# NEXT_PUBLIC_IMMO_LOCAL_API_URL=https://api.asafarim.com/api/v1

ASAFARIM_VIONTO_URL=https://vionto.asafarim.com
ASAFARIM_VIONTO_DEV_URL=http://localhost:3004

ASAFARIM_GITHUB_TOKEN=
