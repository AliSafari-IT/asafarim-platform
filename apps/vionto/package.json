{
  "name": "vionto",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "worker:dev": "tsx --import ./scripts/preload-env.mjs worker.ts",
    "worker:build": "tsup --config tsup.worker.config.ts",
    "populate-music-library": "dotenv -e ../../.env.local -e ../../.env -- tsx scripts/populate-music-library.ts",
    "upload-music": "node scripts/upload-music-to-spaces.mjs",
    "build": "next build",
    "start": "next start --port 3004",
    "lint": "echo \"Lint skipped for Next.js 16 app; covered by typecheck/build\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .next .turbo node_modules worker-dist"
  },
  "dependencies": {
    "@asafarim/auth": "workspace:*",
    "@asafarim/country-language-selector": "workspace:*",
    "@asafarim/db": "workspace:*",
    "@asafarim/shared-i18n": "workspace:*",
    "@asafarim/vionto-schemas": "workspace:*",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@smithy/types": "^4.14.1",
    "bullmq": "^5.34.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.462.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.28",
    "openai": "^4.73.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.33.5",
    "tsx": "^4.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
