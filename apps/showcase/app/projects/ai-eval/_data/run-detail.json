                "safety": 1
              },
              "latencyMs": 942,
              "costUsd": 0.000337,
              "note": null
            },
            {
              "modelId": "compact-c",
              "label": "Compact C",
              "output": {
                "answer": "The cables are made of gold.",
                "citations": [
                  "p2"
                ]
              },
              "scores": {
                "correctness": 0,
