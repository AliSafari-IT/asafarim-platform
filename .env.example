# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=asafarim
POSTGRES_PASSWORD=change_me
POSTGRES_DB=asafarim
# Local dev (docker compose up -d postgres): host 127.0.0.1:55435
# Use 127.0.0.1, not `localhost` — on some Windows/Docker Desktop setups
# `localhost` resolves to IPv6 first and the IPv6 port-forward can silently
# drop queries after the TCP handshake succeeds (Prisma P1017 ConnectionClosed).
# Production (inside compose network): host postgres:5432
DATABASE_URL=postgresql://asafarim:change_me@127.0.0.1:55435/asafarim

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change_me
# Public URL of the app handling auth (the Hub)
AUTH_URL=https://hub.asafarim.com
AUTH_TRUST_HOST=true
# Cookie domain for cross-subdomain SSO.
# Production: .asafarim.com — Development: leave empty (defaults to localhost)
AUTH_COOKIE_DOMAIN=

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Optional — informational only, NextAuth derives the callback from AUTH_URL.
AUTH_GOOGLE_CALLBACK_URL=https://hub.asafarim.com/api/auth/callback/google

# ─── Email One-Time Login Code (OTP) ─────────────────────────────────────────
# Duration a one-time login code is valid (minutes). Default: 10
EMAIL_LOGIN_CODE_TTL_MINUTES=10
# Max code requests per email per window before rate-limiting. Default: 5
EMAIL_CODE_MAX_REQUESTS=5
# Sliding window for request rate limit (minutes). Default: 15
EMAIL_CODE_REQUEST_WINDOW_MINUTES=15
# Max failed verify attempts per code before it is locked. Default: 5
EMAIL_CODE_MAX_ATTEMPTS=5
# Reserved for a future password-reset-by-email flow (not yet implemented).
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ─── SMTP (email delivery for OTP login codes) ───────────────────────────────
# Any standard SMTP provider (e.g. your domain registrar's mail, SendGrid,
# Postmark, SES SMTP interface). Required for the "Email code" sign-in method
# to actually send mail — without it, requesting a code fails with a clear
# "SMTP configuration is incomplete" error rather than pretending to send.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ASafarIM <no-reply@asafarim.com>"
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
# Optional: bcc every outgoing login-code email (e.g. for support visibility)
SMTP_BCC=
# Optional verbose SMTP transport logging — leave off unless debugging delivery.
SMTP_DEBUG=false
SMTP_LOGGING=false

# ─── Database seed (pnpm db:seed) ────────────────────────────────────────────
# When set, the seed creates this user with the superadmin role.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ─── Branding ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_COMPANY_NAME="ASafarIM Digital"
NEXT_PUBLIC_PLATFORM_NAME="ASafarIM Platform"
NEXT_PUBLIC_HUB_NAME="ASafarIM Hub"

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEB_URL=https://asafarim.com
NEXT_PUBLIC_HUB_URL=https://hub.asafarim.com
NEXT_PUBLIC_ADMIN_URL=https://admin.asafarim.com
NEXT_PUBLIC_API_URL=https://api.asafarim.com
NEXT_PUBLIC_SHOWCASE_URL=https://showcase.asafarim.be
NEXT_PUBLIC_VIONTO_URL=https://vionto.asafarim.com

# ─── AI providers ────────────────────────────────────────────────────────────
# Used by apps/vionto for image captions (vision) and story generation.
# Benchmarks in this repo (ai-eval, testora, edumatch) still run in
# fixture-mode against committed synthetic data, not live provider calls.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=8000
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_VISION_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=2000

# ─── Transactional email / misc third-party APIs ────────────────────────────
RESEND_API_KEY=
FROM_EMAIL="ASafarIM <noreply@asafarim.com>"
# Vionto TTS providers (any one is enough; Azure is preferred, then ElevenLabs)
AZURE_SPEECH_KEY=
ELEVENLABS_API_KEY=
# Vionto background-music search
PIXABAY_API_KEY=

# ─── Vionto (apps/vionto) — photo-to-story video pipeline ───────────────────
# Redis backs the vionto-render BullMQ queue shared by the web app and worker.
# Local dev (docker compose up -d redis): host 127.0.0.1:6390
REDIS_URL=redis://localhost:6390
# Worker health endpoint port (web app runs on 3004 in dev)
WORKER_HEALTH_PORT=3007
# FFmpeg/ffprobe binaries — leave empty when they are on PATH.
FFMPEG_PATH=
FFPROBE_PATH=
# Storage: "local" writes under apps/vionto/.local-storage/uploads (dev);
# "spaces" uses DigitalOcean Spaces via the S3 API (production).
VIONTO_STORAGE_DRIVER=local
# Required when VIONTO_STORAGE_DRIVER=local and web/worker run from different
# working directories: absolute path both processes can reach.
VIONTO_LOCAL_STORAGE_DIR=
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=fra1
DO_SPACES_BUCKET=
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_PUBLIC_URL=

# ─── Google Photos import (Vionto, optional) ────────────────────────────────
# Separate incremental OAuth from login; needs the Photos Picker scope enabled
# on the consent screen. For local dev the redirect URI is
# http://localhost:3004/api/integrations/google-photos/callback
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=
GOOGLE_PHOTOS_REDIRECT_URI=
GOOGLE_PHOTOS_SCOPES=https://www.googleapis.com/auth/photospicker.mediaitems.readonly
# Direct shared-album-URL import needs a Google-verified restricted scope;
# leave unset until approved (shared-album links fall back to the picker).
GOOGLE_PHOTOS_SHARING_ENABLED=
# 32-byte AES-256-GCM key for encrypting stored OAuth tokens (openssl rand -hex 32).
VIONTO_TOKEN_ENCRYPTION_KEY=
