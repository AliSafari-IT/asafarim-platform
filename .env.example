# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=asafarim
POSTGRES_PASSWORD=change_me
POSTGRES_DB=asafarim
# Local dev (docker compose up -d postgres): host localhost:55435
# Production (inside compose network): host postgres:5432
DATABASE_URL=postgresql://asafarim:change_me@localhost:55435/asafarim

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change_me
# Public URL of the app handling auth (the Hub)
AUTH_URL=https://hub.asafarim.com
AUTH_TRUST_HOST=true
# Cookie domain for cross-subdomain SSO.
# Production: .asafarim.com — Development: leave empty (defaults to localhost)
AUTH_COOKIE_DOMAIN=

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Email One-Time Login Code (OTP) ─────────────────────────────────────────
# Duration a one-time login code is valid (minutes). Default: 10
EMAIL_LOGIN_CODE_TTL_MINUTES=10
# Max code requests per email per window before rate-limiting. Default: 5
EMAIL_CODE_MAX_REQUESTS=5
# Sliding window for request rate limit (minutes). Default: 15
EMAIL_CODE_REQUEST_WINDOW_MINUTES=15
# Max failed verify attempts per code before it is locked. Default: 5
EMAIL_CODE_MAX_ATTEMPTS=5

# ─── Database seed (pnpm db:seed) ────────────────────────────────────────────
# When set, the seed creates this user with the superadmin role.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ─── Branding ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_COMPANY_NAME="ASafarIM Digital"
NEXT_PUBLIC_PLATFORM_NAME="ASafarIM Platform"
NEXT_PUBLIC_HUB_NAME="ASafarIM Hub"

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEB_URL=https://asafarim.com
NEXT_PUBLIC_HUB_URL=https://hub.asafarim.com
NEXT_PUBLIC_ADMIN_URL=https://admin.asafarim.com
NEXT_PUBLIC_API_URL=https://api.asafarim.com
NEXT_PUBLIC_SHOWCASE_URL=https://showcase.asafarim.be
