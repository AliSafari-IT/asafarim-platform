# Production environment — copy to .env.production, encrypt with Envage, and
# provision the private key on the VPS. Never commit the plaintext file.

NODE_ENV=production

# ─── Database (inside the compose network) ───────────────────────────────────
POSTGRES_USER=asafarim
POSTGRES_PASSWORD=change_me
POSTGRES_DB=asafarim
DATABASE_URL=postgresql://asafarim:change_me@postgres:5432/asafarim

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change_me
AUTH_URL=https://hub.asafarim.com
NEXTAUTH_URL=https://hub.asafarim.com
AUTH_TRUST_HOST=true
# Cross-subdomain SSO cookie domain
AUTH_COOKIE_DOMAIN=.asafarim.com

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GOOGLE_CALLBACK_URL=https://hub.asafarim.com/api/auth/callback/google

# ─── Email One-Time Login Code (OTP) ─────────────────────────────────────────
EMAIL_LOGIN_CODE_TTL_MINUTES=10
EMAIL_CODE_MAX_REQUESTS=5
EMAIL_CODE_REQUEST_WINDOW_MINUTES=15
EMAIL_CODE_MAX_ATTEMPTS=5
# Reserved for a future password-reset-by-email flow (not yet implemented).
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ─── SMTP (email delivery for OTP login codes) ───────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ASafarIM <no-reply@asafarim.com>"
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_BCC=
SMTP_DEBUG=false
SMTP_LOGGING=false

# ─── Branding ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_COMPANY_NAME="ASafarIM Digital"
NEXT_PUBLIC_PLATFORM_NAME="ASafarIM Platform"
NEXT_PUBLIC_HUB_NAME="ASafarIM Hub"

# ─── App URLs (production domains) ───────────────────────────────────────────
NEXT_PUBLIC_WEB_URL=https://asafarim.com
NEXT_PUBLIC_HUB_URL=https://hub.asafarim.com
NEXT_PUBLIC_SHOWCASE_URL=https://showcase.asafarim.be
NEXT_PUBLIC_ADMIN_URL=https://admin.asafarim.com
NEXT_PUBLIC_API_URL=https://api.asafarim.com

# ─── AI providers (reserved — not yet wired into any app/benchmark code) ─────
# Benchmarks in this repo (ai-eval, testora, edumatch, vionto) run in
# fixture-mode against committed synthetic data, not live provider calls.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=8000
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=2000

# ─── Transactional email / misc third-party APIs (reserved) ─────────────────
RESEND_API_KEY=
FROM_EMAIL="ASafarIM <noreply@asafarim.com>"
ELEVENLABS_API_KEY=
PIXABAY_API_KEY=

# ─── Vionto real-pipeline integrations (reserved — benchmark is fixture-only)
REDIS_URL=redis://redis:6379
FFMPEG_PATH=
KLING_API_KEY=
KLING_API_SECRET=
# OAuth client in the "asafarim-platform-vionto" Google Cloud project
# (585671975647-…). Both this URI and the localhost dev URI are registered.
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=
GOOGLE_PHOTOS_REDIRECT_URI=https://vionto.asafarim.com/api/integrations/google-photos/callback
GOOGLE_PHOTOS_SCOPES=https://www.googleapis.com/auth/photospicker.mediaitems.readonly
# 32-byte AES-256-GCM key for encrypting stored OAuth tokens (openssl rand -hex 32).
VIONTO_TOKEN_ENCRYPTION_KEY=
