# Production environment — copy to .env.production, encrypt with Envage, and
# provision the private key on the VPS. Never commit the plaintext file.

NODE_ENV=production

# VPS address used by infra/scripts/deploy-prod.sh (exported SERVER_HOST wins).
SERVER_HOST=your_vps_ip_or_domain
NEXT_PUBLIC_SERVER_HOST=your_vps_ip_or_domain

# ─── Database (inside the compose network) ───────────────────────────────────
POSTGRES_USER=asafarim
POSTGRES_PASSWORD=change_me
POSTGRES_DB=asafarim
DATABASE_URL=postgresql://asafarim:change_me@postgres:5432/asafarim

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change_me
AUTH_URL=https://hub.asafarim.com
NEXTAUTH_URL=https://hub.asafarim.com
AUTH_TRUST_HOST=true
# Cross-subdomain SSO cookie domain
AUTH_COOKIE_DOMAIN=.asafarim.com

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GOOGLE_CALLBACK_URL=https://hub.asafarim.com/api/auth/callback/google

# ─── Email One-Time Login Code (OTP) ─────────────────────────────────────────
EMAIL_LOGIN_CODE_TTL_MINUTES=10
EMAIL_CODE_MAX_REQUESTS=5
EMAIL_CODE_REQUEST_WINDOW_MINUTES=15
EMAIL_CODE_MAX_ATTEMPTS=5
# Reserved for a future password-reset-by-email flow (not yet implemented).
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ─── SMTP (email delivery for OTP login codes) ───────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ASafarIM <no-reply@asafarim.com>"
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_BCC=
SMTP_DEBUG=false
SMTP_LOGGING=false

# ─── Branding ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_COMPANY_NAME="ASafarIM Digital"
NEXT_PUBLIC_PLATFORM_NAME="ASafarIM Platform"
NEXT_PUBLIC_HUB_NAME="ASafarIM Hub"
NEXT_PUBLIC_SHOWCASE_NAME="ASafarIM Showcases"
NEXT_PUBLIC_ADMIN_NAME="ASafarIM Admin Console"
NEXT_PUBLIC_VIONTO_NAME="ASafarIM Vionto"
NEXT_PUBLIC_TESTORA_NAME="ASafarIM Testora"
NEXT_PUBLIC_APPBUILDER_NAME="ASafarIM Appbuilder"

# ─── App URLs (production domains) ───────────────────────────────────────────
NEXT_PUBLIC_WEB_URL=https://asafarim.com
NEXT_PUBLIC_HUB_URL=https://hub.asafarim.com
NEXT_PUBLIC_SHOWCASE_URL=https://showcase.asafarim.be
NEXT_PUBLIC_ADMIN_URL=https://admin.asafarim.com
NEXT_PUBLIC_VIONTO_URL=https://vionto.asafarim.com
NEXT_PUBLIC_TESTORA_URL=https://testora.asafarim.com
NEXT_PUBLIC_APPBUILDER_URL=https://appbuilder.asafarim.com
NEXT_PUBLIC_API_URL=https://api.asafarim.com

# ─── testora (own database + private-app unlock) ─────────────────────────────
# Password for testora's own Postgres (compose interpolates this into the
# testora-postgres service and the TESTORA_DATABASE_URL connection string).
TESTORA_DB_PASSWORD=<openssl rand -hex 24>
# Signs the "unlock" cookie for private apps (openssl rand -hex 32).
TESTORA_SECRET=<openssl rand -hex 32>

# ─── appbuilder (own database) ────────────────────────────────────────────────
# Password for appbuilder's own Postgres (compose interpolates this into the
# appbuilder-postgres service and the APPBUILDER_DATABASE_URL connection
# string used by the appbuilder-migrate job). Never reuse DATABASE_URL for
# AppBuilder product data — see docs/appbuilder-architecture.md.
APPBUILDER_DB_PASSWORD=<openssl rand -hex 24>

# ─── appbuilder M07 AI generation pipeline ────────────────────────────────────
# Read only by the appbuilder-worker service (docker-compose.prod.yml), never
# the Next.js app. See docs/appbuilder-m07-ai-generation.md. Defaults to the
# deterministic "fake" provider so this service is never billable until an
# operator deliberately sets APPBUILDER_AI_PROVIDER=openai.
APPBUILDER_AI_PROVIDER=fake
# Leave blank to fall back to the shared OPENAI_API_KEY/OPENAI_MODEL below.
APPBUILDER_AI_OPENAI_API_KEY=
APPBUILDER_WORKER_CONCURRENCY=2

# ─── AI providers (shared platform keys) ─────────────────────────────────────
# OPENAI_API_KEY/OPENAI_MODEL are shared across apps that opt in — appbuilder's
# worker falls back to these when APPBUILDER_AI_OPENAI_API_KEY is unset.
# Benchmarks in this repo (ai-eval, testora, edumatch, vionto) run in
# fixture-mode against committed synthetic data, not live provider calls.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=8000
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=2000

# ─── Transactional email / misc third-party APIs (reserved) ─────────────────
RESEND_API_KEY=
FROM_EMAIL="ASafarIM <noreply@asafarim.com>"
ELEVENLABS_API_KEY=
PIXABAY_API_KEY=

# ─── Vionto real-pipeline integrations (reserved — benchmark is fixture-only)
REDIS_URL=redis://redis:6379
FFMPEG_PATH=
# Kling AI image-to-video (AI motion clips). JWT auth is built server-side
# from these keys — never expose them via NEXT_PUBLIC_*.
KLING_API_KEY=
KLING_API_SECRET=
# Optional overrides — defaults: https://api-singapore.klingai.com / kling-v1-6
KLING_API_BASE=
KLING_MODEL=
# AI-director provider keys (server env fallback; users may override via BYOK).
# Only set what you use — the app degrades gracefully when a provider is absent.
FAL_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=
# OAuth client in the "asafarim-platform-vionto" Google Cloud project
# (585671975647-…). Both this URI and the localhost dev URI are registered.
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=
GOOGLE_PHOTOS_REDIRECT_URI=https://vionto.asafarim.com/api/integrations/google-photos/callback
GOOGLE_PHOTOS_SCOPES=https://www.googleapis.com/auth/photospicker.mediaitems.readonly
# 32-byte AES-256-GCM key for encrypting stored OAuth tokens (openssl rand -hex 32).
VIONTO_TOKEN_ENCRYPTION_KEY=

# DO Spaces bucket configuration
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_PUBLIC_URL=https://asafarim-platform.fra1.digitaloceanspaces.com
DO_SPACES_ACCESS_KEY_ID=DO00Y26UMAWPH22UR864
DO_SPACES_SECRET_ACCESS_KEY=<paste the full secret key from the modal>
DO_SPACES_BUCKET_NAME=asafarim-platform
DO_SPACES_REGION=fra1
# Optional: explicit public URL for loaded objects. Defaults to the bucket subdomain
# of the endpoint (e.g. https://asafarim-platform.fra1.digitaloceanspaces.com).
# DO_SPACES_PUBLIC_URL=https://asafarim-platform.fra1.digitaloceanspaces.com


# Webhook secrets (optional)
WEBHOOK_SECRET_DISCORD=<Generate a secure random discord webhook secret>
