asafarim.com {
  reverse_proxy web:3000
}

www.asafarim.com {
  reverse_proxy web:3000
}

hub.asafarim.com {
  reverse_proxy hub:3000
}

admin.asafarim.com {
  reverse_proxy admin:3000
}

showcase.asafarim.be {
  reverse_proxy showcase:3000
}

vionto.asafarim.com {
  # Media uploads can be large; give the proxy generous timeouts.
  reverse_proxy vionto:3000 {
    transport http {
      read_timeout 600s
      write_timeout 600s
    }
  }
}
