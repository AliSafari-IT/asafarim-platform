{
  "name": "@asafarim/appbuilder-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Approved component/template registry and metadata-driven preview renderer for AppBuilder generated apps — no database, auth, AI, or Next.js dependency.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles/preview.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@asafarim/appbuilder-schema": "workspace:*",
    "@asafarim/ui": "workspace:*",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@asafarim/config": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
