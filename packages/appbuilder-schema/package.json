{
  "name": "@asafarim/appbuilder-schema",
  "version": "0.1.0",
  "private": true,
  "description": "Versioned AppBuilder application-specification contract and deterministic controlled-operation engine — no Next.js, database, auth, AI, or browser dependency.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./fixtures": "./src/fixtures/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:json-schema": "tsx scripts/generate-json-schema.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@asafarim/config": "workspace:*",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
