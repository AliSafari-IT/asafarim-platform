{
  "name": "@asafarim/db",
  "version": "0.2.0",
  "private": true,
  "description": "Shared PostgreSQL/Prisma database package for the ASafarIM Platform",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0"
  },
  "devDependencies": {
    "@asafarim/config": "workspace:*",
    "@types/node": "^24.0.0",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "dotenv-cli": "^7.4.2",
    "prisma": "7.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
