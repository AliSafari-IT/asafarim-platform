# Local development environment — copy to .env at the repo root.
# Apps load the root .env via next.config.ts; Prisma via dotenv-cli.

# ─── Database (docker compose up -d postgres) ────────────────────────────────
POSTGRES_USER=asafarim
POSTGRES_PASSWORD=asafarim_dev
POSTGRES_DB=asafarim
# Host port 55435 — see docker-compose.yml (5432 often taken locally).
# Use 127.0.0.1, not `localhost` — on some Windows/Docker Desktop setups
# `localhost` resolves to IPv6 first and the IPv6 port-forward can silently
# drop queries after the TCP handshake succeeds (Prisma P1017 ConnectionClosed).
DATABASE_URL=postgresql://asafarim:asafarim_dev@127.0.0.1:55435/asafarim

# testora keeps its own database (drizzle/pg), separate from the shared Prisma
# Postgres above. Container: e2e-testora-db on host port 55434.
TESTORA_DATABASE_URL=postgres://e2e_testora:e2e_testora@localhost:55434/e2e-testing-db

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
AUTH_SECRET=dev-secret-change-me-32-chars-minimum
AUTH_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true
# Leave empty in development (cookies default to localhost, shared across ports)
AUTH_COOKIE_DOMAIN=

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/callback/google

# ─── Email One-Time Login Code (OTP) ─────────────────────────────────────────
# Duration a one-time login code is valid (minutes). Default: 10
EMAIL_LOGIN_CODE_TTL_MINUTES=10
# Max code requests per email per window before rate-limiting. Default: 5
EMAIL_CODE_MAX_REQUESTS=5
# Sliding window for request rate limit (minutes). Default: 15
EMAIL_CODE_REQUEST_WINDOW_MINUTES=15
# Max failed verify attempts per code before it is locked. Default: 5
EMAIL_CODE_MAX_ATTEMPTS=5
# Reserved for a future password-reset-by-email flow (not yet implemented).
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ─── SMTP (email delivery for OTP login codes) ───────────────────────────────
# Required for the "Email code" sign-in method to actually send mail locally.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ASafarIM <no-reply@asafarim.com>"
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_BCC=
# Optional verbose SMTP transport logging — leave off unless debugging delivery.
SMTP_DEBUG=false
SMTP_LOGGING=false

# ─── Database seed (pnpm db:seed) ────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@asafarim.com
SEED_ADMIN_PASSWORD=Admin+123456

# ─── Branding ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_COMPANY_NAME="ASafarIM Digital"
NEXT_PUBLIC_PLATFORM_NAME="ASafarIM Platform"
NEXT_PUBLIC_HUB_NAME="ASafarIM Hub"

# ─── App URLs (local dev ports) ──────────────────────────────────────────────
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_HUB_URL=http://localhost:3001
NEXT_PUBLIC_SHOWCASE_URL=http://localhost:3002
NEXT_PUBLIC_ADMIN_URL=http://localhost:3003
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── AI providers (reserved — not yet wired into any app/benchmark code) ─────
# Benchmarks in this repo (ai-eval, testora, edumatch, vionto) run in
# fixture-mode against committed synthetic data, not live provider calls.
# These are here so real-provider integration work can pick them up later.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=8000
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=2000

# ─── Transactional email / misc third-party APIs (reserved) ─────────────────
RESEND_API_KEY=
FROM_EMAIL="ASafarIM <noreply@asafarim.com>"
ELEVENLABS_API_KEY=
PIXABAY_API_KEY=

# ─── Vionto real-pipeline integrations (reserved — benchmark is fixture-only)
# REDIS_URL/FFMPEG_PATH/KLING_*/GOOGLE_PHOTOS_* only matter once Vionto grows
# past benchmarks/vionto's synthetic showcase into a real rendering pipeline.
REDIS_URL=redis://localhost:6379
FFMPEG_PATH=
KLING_API_KEY=
KLING_API_SECRET=
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=
GOOGLE_PHOTOS_REDIRECT_URI=
GOOGLE_PHOTOS_SCOPES=https://www.googleapis.com/auth/photospicker.mediaitems.readonly
# 32-byte AES-256-GCM key for encrypting stored OAuth tokens (openssl rand -hex 32).
VIONTO_TOKEN_ENCRYPTION_KEY=


# DO Spaces bucket configuration
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_PUBLIC_URL=https://asafarim-platform.fra1.digitaloceanspaces.com
DO_SPACES_ACCESS_KEY_ID=DO00Y26UMAWPH22UR864
DO_SPACES_SECRET_ACCESS_KEY=<paste the full secret key from the modal>
DO_SPACES_BUCKET_NAME=asafarim-platform
DO_SPACES_REGION=fra1
# Optional: explicit public URL for loaded objects. Defaults to the bucket subdomain
# of the endpoint (e.g. https://asafarim-platform.fra1.digitaloceanspaces.com).
# DO_SPACES_PUBLIC_URL=https://asafarim-platform.fra1.digitaloceanspaces.com

